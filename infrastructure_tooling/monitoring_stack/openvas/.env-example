# OpenVAS / Greenbone Community Edition Configuration

# Admin password for the GSA web interface (change immediately after first login)
GVM_ADMIN_PASSWORD=admin

# Feed release version (leave empty for latest)
GREENBONE_FEED_RELEASE=

# Web interface ports
GSA_PORT=9392
NGINX_HTTPS_PORT=443

# PostgreSQL settings
POSTGRES_DB=gvmd
POSTGRES_USER=gvmd
POSTGRES_PASSWORD=changeme
